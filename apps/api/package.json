{
  "name": "api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/src/main",
    "lint": "eslint src --ext .ts",
    "check-types": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "npx tsx seed.ts",
    "db:reset": "npx tsx reset-db.ts",
    "db:fresh": "pnpm db:reset && pnpm db:migrate && pnpm db:seed"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1007.0",
    "@aws-sdk/s3-request-presigner": "^3.1007.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/throttler": "^6.5.0",
    "@orpc/nest": "^1.13.6",
    "@orpc/openapi": "^1.13.6",
    "@orpc/server": "^1.13.6",
    "@orpc/zod": "^1.13.6",
    "@repo/contract": "workspace:*",
    "@repo/schemas": "workspace:*",
    "@scalar/nestjs-api-reference": "latest",
    "@sentry/nestjs": "^10.39.0",
    "better-auth": "latest",
    "drizzle-orm": "^0.44.0",
    "helmet": "^8.1.0",
    "multer": "^2.1.0",
    "pg": "^8.13.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "zod": "^4.1.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@swc/cli": "^0.3.0",
    "@swc/core": "^1.4.0",
    "@types/express": "^4.17.0",
    "@types/multer": "^2.0.0",
    "@types/pg": "^8.0.0",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.4",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0"
  }
}
